# Environment
.env

# Composer
/vendor/

# Writable directory (runtime files, not source code)
/writable/cache/*
!/writable/cache/index.html
/writable/debugbar/*
!/writable/debugbar/index.html
/writable/logs/*
!/writable/logs/index.html
/writable/session/*
!/writable/session/index.html
/writable/uploads/*
!/writable/uploads/index.html

# OS / editor cruft
.DS_Store
Thumbs.db
